# ============================================================
# PC-Agent — Environment Configuration
# Copy this file to the project root (next to main.py)
# ============================================================

# ── Discord ─────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here

# ── Bot ─────────────────────────────────────────────────────
BOT_PREFIX=!
# Comma-separated Discord user IDs who own the bot
OWNER_IDS=123456789012345678
# Comma-separated guild IDs the bot is allowed in (leave empty = all)
ALLOWED_GUILDS=

# ── Security ─────────────────────────────────────────────────
REQUIRE_ADMIN_ROLE=false
ADMIN_ROLE_NAME=PC-Admin
SECRET_PASSPHRASE=

# ── Monitoring ───────────────────────────────────────────────
CPU_ALERT_THRESHOLD=90
RAM_ALERT_THRESHOLD=90
DISK_ALERT_THRESHOLD=95
MONITOR_INTERVAL=60

# ── Screenshot ───────────────────────────────────────────────
SCREENSHOT_QUALITY=85
MAX_SCREENSHOT_SIZE=8388608

# ── Voice / TTS ──────────────────────────────────────────────
VOICE_LANGUAGE=en-US
TTS_ENGINE=pyttsx3

# ── Files ────────────────────────────────────────────────────
MAX_FILE_SIZE=25000000

# ── Database ─────────────────────────────────────────────────
DB_PATH=data/pcagent.db

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/pcagent.log

# ── Scheduler ────────────────────────────────────────────────
MAX_SCHEDULED_TASKS=50
